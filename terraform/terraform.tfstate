            "content": "openapi: \"3.0.1\"\ninfo:\n  title: \"ApiOps Echo Service\"\n  version: \"1.0.0\"\n  description: \"A minimal OpenAPI spec with only the /anything GET endpoint.\"\nservers:\n  - url: \"https://httpbin.org\"\n    description: \"DCGW Production server\"\n\n# Kong-specific extensions - Also change apis.yaml Lines 42 and 49 must match this name\nx-kong-name: \"rami-apiops-demo\"\nx-kong-service-defaults:\n  retries: 6\n  connect_timeout: 60000\n  write_timeout: 60000\n  read_timeout: 60000\n\n# Global Kong plugins\n# x-kong-plugin-key-auth:\n#   enabled: true\n#   config:\n#     key_names: [\"apiKey\"]\n#     key_in_header: true\n#     key_in_query: false\n#     hide_credentials: true\n\nx-kong-plugin-rate-limiting:\n  enabled: true\n  config:\n    minute: 90\n    hour: 1000\n    policy: \"local\"\n    hide_client_headers: false\n\nx-kong-tags: [ \"owner=rami\", \"created_by:terraform\", \"environment:dev\" ]\n\npaths:\n  /anything:\n    get:\n      operationId: Httpbin-Anything\n      summary: \"Returns anything passed in request data.\"\n      description: \"Returns anything that is passed to request. Useful for testing HTTP methods and request data.\"\n      tags:\n        - \"Testing\"\n      parameters:\n        - name: \"test\"\n          in: \"query\"\n          description: \"Test parameter\"\n          required: false\n          schema:\n            type: \"string\"\n      responses:\n        '200':\n          description: \"Request data\"\n          content:\n            application/json:\n              schema:\n                type: object\n                properties:\n                  method:\n                    type: string\n                    description: \"HTTP method used\"\n                    example: \"GET\"\n                  url:\n                    type: string\n                    description: \"Request URL\"\n                    example: \"https://httpbin.org/anything\"\n                  args:\n                    type: object\n                    description: \"Query string arguments\"\n                    example: {}\n                  headers:\n                    type: object\n                    description: \"Request headers\"\n                    example:\n                      Accept: \"*/*\"\n                      Host: \"httpbin.org\"\n                  data:\n                    type: string\n                    description: \"Request body data\"\n                    example: \"\"\n                  json:\n                    type: object\n                    description: \"JSON request body\"\n                    example: null\n                  origin:\n                    type: string\n                    description: \"Client IP address\"\n                    example: \"127.0.0.1\"\n              example:\n                method: \"GET\"\n                url: \"https://httpbin.org/anything\"\n                args: {}\n                headers:\n                  Accept: \"*/*\"\n                  Host: \"httpbin.org\"\n                data: \"\"\n                json: null\n                origin: \"127.0.0.1\"\n        '429':\n          description: \"Too Many Requests\"\n          content:\n            application/json:\n              schema:\n                type: object\n                properties:\n                  message:\n                    type: string\n                    example: \"API rate limit exceeded\"\n        '401':\n          description: \"Unauthorized\"\n          content:\n            application/json:\n              schema:\n                type: object\n                properties:\n                  message:\n                    type: string\n                    example: \"Invalid API key\"\n\n  /post:\n    post:\n      operationId: Httpbin-Post\n      summary: \"Httpbin POST data\"\n      description: \"Returns the posted data back\"\n      tags:\n        - \"Testing\"\n      requestBody:\n        required: true\n        content:\n          application/json:\n            schema:\n              type: object\n              additionalProperties: true\n      responses:\n        '200':\n          description: \"Echoed data\"\n          content:\n            application/json:\n              schema:\n                type: object\n                properties:\n                  echoed_data:\n                    type: object\n                  timestamp:\n                    type: string\n                    format: date-time\n",
            "created_at": "2026-03-31T09:19:44.695Z",
            "id": "9fbc09ca-2bac-4398-aa89-6960a75c6090",
            "type": "oas3",
            "updated_at": "2026-03-31T09:19:44.695Z",
            "validation_messages": []
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "dependencies": [
            "konnect_api.apis"
          ]
        }
      ]
    },
