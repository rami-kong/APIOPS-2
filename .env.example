# ─────────────────────────────────────────────────────────
# Kong APIOps E2E Demo — Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit your .env file to version control.

# Kong Konnect Personal Access Token (PAT)
KONNECT_PAT=kpat_REPLACE_ME

# Kong Konnect API address (US region)
KONNECT_ADDR=https://us.api.konghq.com

# The name of the Control Plane in Konnect
CONTROL_PLANE_NAME=apiops-demo-cp

# Control Plane ID (UUID from Konnect)
CONTROL_PLANE_ID=2c719ee7-7bb1-4058-9093-75af32ec84f5
